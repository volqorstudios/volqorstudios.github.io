---
const currentPath = Astro.url.pathname;

function isActive(href) {
  if (href === "/") {
    return currentPath === "/";
  }
  
  return currentPath.startsWith(href);
}

const navLinks = [
  { href: "/proyectos/", label: "Proyectos" },
  { href: "/equipo/", label: "Equipo" },
  { href: "/contacto/", label: "Contacto" },
];
---





<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand">
      <span class="brand-name">VOLQOR</span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Abrir menu de navegacion"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
        <line class="nav-toggle-line-top" x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        <line class="nav-toggle-line-middle" x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        <line class="nav-toggle-line-bottom" x1="3" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>

    <nav class="site-nav" id="site-nav" aria-label="Navegacion principal">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={isActive(link.href) ? "nav-link is-active" : "nav-link"}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 3px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: 18px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.04em;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: 2px solid var(--color-border);
    color: var(--color-text);
    padding: 6px;
    cursor: pointer;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-text-dim);
    font-size: 0.95rem;
    font-weight: 600;
    padding-block: 4px;
    border-bottom: 3px solid transparent;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link.is-active {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .header-inner {
      position: relative;
    }

    .nav-toggle {
      display: flex;
      position: relative;
      z-index: 2;
    }

    .nav-toggle svg line {
      transform-box: fill-box;
      transform-origin: center;
      transition:
        transform 0.25s ease,
        opacity 0.25s ease;
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-line-top {
      transform: translateY(6px) rotate(45deg);
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-line-middle {
      opacity: 0;
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-line-bottom {
      transform: translateY(-6px) rotate(-45deg);
    }

    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      width: 100%;
      background: var(--color-bg);
      padding-inline: 24px;
      transform: translateX(100%);
      transition: transform 0.25s ease;
    }

    .site-nav.is-open {
      transform: translateX(0);
    }

    .nav-link {
      width: 100%;
      padding-block: 10px;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.querySelector(".site-nav");

  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }
</script>
