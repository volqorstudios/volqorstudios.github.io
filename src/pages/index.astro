---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import AsyncImage from "../components/AsyncImage.astro";
import { projects } from "../data/projects.js";

const description =
  "VOLQOR Studios es un estudio independiente de El Salvador que crea aplicaciones utiles y experimenta con inteligencia artificial fuera de lo convencional.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "VOLQOR Studios",
  url: "https://volqorstudios.github.io",
  logo: "https://volqorstudios.github.io/favicon.svg",
  foundingLocation: "El Salvador",
  founder: {
    "@type": "Person",
    name: "Christian",
  },
};
---





<BaseLayout title="Inicio" description={description} path="/" jsonLd={jsonLd}>
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <h1 class="hero-title">
          Aplicaciones utiles.<br />
          Ideas fuera de lo convencional.
        </h1>
        <p class="hero-description">
          VOLQOR Studios es un estudio independiente que disena aplicaciones
          pensadas para resolver problemas reales, y un laboratorio de
          inteligencia artificial donde experimentamos con ideas poco
          convencionales que si funcionan.
        </p>
        <div class="hero-actions">
          <a href="/proyectos/" class="button-primary">Ver proyectos</a>
          <a href="/contact/" class="button-secondary">Contactar</a>
        </div>
      </div>
      <AsyncImage
        src="/imgpages/home/01.svg"
        alt=""
        width="420"
        height="420"
        loading="eager"
        wrapClass="hero-illustration-wrap"
        class="ink-illustration hero-illustration"
      />
    </div>
  </section>

  <section class="about wrap">
    <div class="about-grid">
      <div class="about-block">
        <span class="about-label">ORIGEN</span>
        <p>
          Fundado en El Salvador por Christian, VOLQOR Studios nace de la idea
          de construir herramientas que la gente realmente use, sin relleno ni
          funciones innecesarias.
        </p>
      </div>
      <div class="about-block">
        <span class="about-label">MODELO</span>
        <p>
          Un estudio independiente financiado por sus propios usuarios:
          donaciones voluntarias y publicidad minima, nada invasiva. Sin
          inversionistas de por medio.
        </p>
      </div>
      <div class="about-block">
        <span class="about-label">ENFOQUE</span>
        <p>
          Cada proyecto busca resolver un problema concreto primero, y explorar
          despues. La experimentacion con IA se hace con un objetivo claro: que
          sea util, no solo llamativa.
        </p>
      </div>
    </div>
  </section>

  <section class="wrap manifesto">
    <article class="manifesto-item">
      <div class="manifesto-illustration-wrap">
        <AsyncImage
          src="/imgpages/home/02.svg"
          alt=""
          width="220"
          height="220"
          loading="lazy"
          wrapClass="manifesto-illustration-inner"
          class="ink-illustration manifesto-illustration"
        />
        <svg
          class="prohibition-overlay prohibition-circle"
          viewBox="0 0 120 120"
          aria-hidden="true"
        >
          <circle cx="60" cy="60" r="46"></circle>
          <line x1="25.85" y1="25.85" x2="94.15" y2="94.15"></line>
        </svg>
      </div>
      <div class="manifesto-copy">
        <h3>La creatividad nunca se prohibe.</h3>
        <p>
          Las ideas nacen para compartirse. Mientras sean utiles, no hay codigo
          ni regla que deba frenarlas.
        </p>
      </div>
    </article>

    <article class="manifesto-item">
      <div class="manifesto-illustration-wrap">
        <AsyncImage
          src="/imgpages/home/03.svg"
          alt=""
          width="220"
          height="220"
          loading="lazy"
          wrapClass="manifesto-illustration-inner"
          class="ink-illustration manifesto-illustration"
        />
        <svg
          class="prohibition-overlay prohibition-cross"
          viewBox="0 0 120 120"
          aria-hidden="true"
        >
          <rect x="25" y="25" width="70" height="70" rx="10"></rect>
          <line x1="31" y1="31" x2="89" y2="89"></line>
          <line x1="89" y1="31" x2="31" y2="89"></line>
        </svg>
      </div>
      <div class="manifesto-copy">
        <h3>El tiempo no se gasta en toxicidad.</h3>
        <p>
          Como usuario, tu energia vale mas fomentando lo util que alimentando
          un entorno que frena el progreso.
        </p>
      </div>
    </article>
  </section>

  <section class="projects-preview wrap">
    <div class="section-heading">
      <h2>Proyectos</h2>
      <a href="/proyectos/" class="section-link">Ver todos</a>
    </div>
    <div class="projects-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    border-bottom: 3px solid var(--color-border);
    padding-block: 96px 80px;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    max-width: var(--max-width);
  }

  .hero-copy {
    max-width: 640px;
  }

  .hero-illustration-wrap {
    width: 280px;
    height: 280px;
    flex-shrink: 0;
  }

  .hero-illustration {
    width: 280px;
    height: 280px;
    flex-shrink: 0;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .hero-inner {
      flex-direction: column-reverse;
      text-align: left;
    }

    .hero-illustration-wrap {
      width: 180px;
      height: 180px;
    }

    .hero-illustration {
      width: 180px;
      height: 180px;
    }
  }

  .hero-title {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .hero-description {
    margin-top: 24px;
    font-size: 1.1rem;
    color: var(--color-text-dim);
    max-width: 60ch;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .button-primary,
  .button-secondary {
    display: inline-block;
    padding: 13px 26px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    border: 1px solid transparent;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .button-primary {
    background: var(--color-ink);
    color: var(--color-bg);
    border-color: var(--color-ink);
    box-shadow: 4px 4px 0 var(--color-accent);
  }

  .button-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-ink);
    color: var(--color-ink);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-ink);
  }

  .button-secondary {
    border-color: var(--color-border);
    color: var(--color-text);
    box-shadow: 4px 4px 0 var(--color-ink);
  }

  .button-secondary:hover {
    border-color: var(--color-ink);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-ink);
  }

  .about {
    padding-block: 80px;
    border-bottom: 3px solid var(--color-border);
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .about-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: 14px;
  }

  .about-block p {
    color: var(--color-text-dim);
    font-size: 0.98rem;
  }

  .manifesto {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-block: 16px 64px;
  }

  .manifesto-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .manifesto-item:nth-child(even) {
    align-items: flex-end;
    text-align: right;
  }

  .manifesto-illustration-wrap {
    position: relative;
    width: 220px;
    height: 220px;
    flex-shrink: 0;
  }

  .manifesto-illustration-inner {
    width: 220px;
    height: 220px;
  }

  .manifesto-illustration {
    width: 220px;
    height: 220px;
    object-fit: contain;
  }

  .prohibition-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 4;
    stroke-linecap: round;
  }

  .prohibition-circle circle {
    stroke-dasharray: 289.03;
    stroke-dashoffset: 289.03;
    animation: draw-circle 3.2s ease-in-out infinite;
  }

  .prohibition-circle line {
    stroke-dasharray: 96.6;
    stroke-dashoffset: 96.6;
    animation: draw-bar 3.2s ease-in-out infinite;
    animation-delay: 1.4s;
  }

  .prohibition-cross rect {
    stroke-dasharray: 280;
    stroke-dashoffset: 280;
    animation: draw-box 3.4s ease-in-out infinite;
  }

  .prohibition-cross line:nth-of-type(2) {
    stroke-dasharray: 82.02;
    stroke-dashoffset: 82.02;
    animation: draw-diagonal 3.4s ease-in-out infinite;
    animation-delay: 1.2s;
  }

  .prohibition-cross line:nth-of-type(3) {
    stroke-dasharray: 82.02;
    stroke-dashoffset: 82.02;
    animation: draw-diagonal 3.4s ease-in-out infinite;
    animation-delay: 1.7s;
  }

  @keyframes draw-circle {
    0% {
      stroke-dashoffset: 289.03;
    }
    35%,
    85% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -289.03;
    }
  }

  @keyframes draw-bar {
    0% {
      stroke-dashoffset: 96.6;
    }
    25%,
    85% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -96.6;
    }
  }

  @keyframes draw-box {
    0% {
      stroke-dashoffset: 280;
    }
    35%,
    85% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -280;
    }
  }

  @keyframes draw-diagonal {
    0% {
      stroke-dashoffset: 82.02;
    }
    20%,
    85% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -82.02;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prohibition-circle circle,
    .prohibition-circle line,
    .prohibition-cross rect,
    .prohibition-cross line {
      animation: none;
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 680px) {
    .manifesto-illustration-wrap {
      width: 170px;
      height: 170px;
    }

    .manifesto-illustration-inner {
      width: 170px;
      height: 170px;
    }

    .manifesto-illustration {
      width: 170px;
      height: 170px;
    }

    .manifesto-copy p {
      max-width: none;
    }

    .manifesto-item {
      gap: 44px;
    }

    .manifesto-item:nth-child(even) {
      align-items: flex-start;
      text-align: left;
    }
  }

  .manifesto-copy h3 {
    font-size: 1.35rem;
    max-width: 30ch;
  }

  .manifesto-copy p {
    margin-top: 14px;
    color: var(--color-text-dim);
    font-size: 1rem;
    max-width: 52ch;
  }

  .projects-preview {
    padding-block: 80px;
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .section-heading h2 {
    font-size: 1.8rem;
  }

  .section-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-dim);
    text-decoration: none;
  }

  .section-link:hover {
    color: var(--color-accent);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  @media (max-width: 780px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
