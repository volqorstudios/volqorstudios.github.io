---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AsyncImage from "../../components/AsyncImage.astro";

import { projects, getPlatformIcon } from "../../data/projects.js";
export function getStaticPaths() {
  return projects.map((project) => ({
    params: { project: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const description = `${project.tagline} Disponible para ${project.platform}, desarrollada por VOLQOR Studios.`;
const platformIcon = getPlatformIcon(project.platform);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: project.name,
  description: project.description,
  applicationCategory: "BusinessApplication",
  operatingSystem: project.platform,
  author: {
    "@type": "Organization",
    name: "VOLQOR Studios",
  },
};
---





<BaseLayout
  title={project.name}
  description={description}
  path={`/proyectos/${project.slug}/`}
  jsonLd={jsonLd}
>
  <article class="wrap project-detail">
    <a href="/proyectos/" class="back-link">&larr; Todos los proyectos</a>
    <header class="project-header">
      <div class="project-hero">
        {
          project.icon && (
            <AsyncImage
              src={project.icon}
              alt=""
              width="96"
              height="96"
              wrapClass="project-icon-wrap"
              class="project-icon"
            />
          )
        }
        <h1>{project.name}</h1>
        <p class="project-tagline">{project.tagline}</p>
      </div>
      <div class="project-download-grid">
        <div class="download-cell">
          {
            platformIcon && (
              <img
                src={platformIcon}
                alt=""
                width="40"
                height="40"
                class="download-cell-icon"
              />
            )
          }
          <span class="download-cell-platform">
            {project.platform}
          </span>

          <a
            href={project.downloadUrl}
            class="button-primary"
            rel="noopener noreferrer"
            target="_blank"
          >
            Descargar en Google Play
          </a>
        </div>
      </div>
    </header>

    <section class="project-section">
      <h2>Sobre la aplicacion</h2>
      <p>{project.description}</p>
    </section>
    <section class="project-section">
      <h2>Funciones principales</h2>
      <div class="features-grid">
        {
          project.features.map((feature) => (
            <div class="feature-item">
              <h3>{feature.title}</h3>
              <p>{feature.detail}</p>
            </div>
          ))
        }
      </div>
    </section>
    <section class="project-section">
      <h2>Para quien es</h2>
      <p>{project.audience}</p>
    </section>
    <section class="project-section">
      <h2>Informacion de uso</h2>
      <p>
        Consulta como esta aplicacion maneja tu informacion antes de
        descargarla.
      </p>
      <a
        href={`/proyectos/${project.slug}/politica-de-privacidad/`}
        class="button-secondary"
      >
        Politica de privacidad
      </a>
    </section>
    <section class="project-section">
      <h2>Open Source</h2>
      {
        project.openSource && project.openSource.length > 0 ? (
          <div class="open-source-grid">
            {project.openSource.map((resource) => (
              <a
                href={resource.url}
                target="_blank"
                rel="noopener noreferrer"
                class="open-source-item"
              >
                <h3>{resource.name}</h3>
                <p>{resource.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p>Este proyecto todavia no tiene recursos open source publicados.</p>
        )
      }
    </section>
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding-block: 56px 96px;
    max-width: 780px;
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-dim);
    text-decoration: none;
    margin-bottom: 40px;
  }
  .back-link:hover {
    color: var(--color-accent);
  }
  .project-header {
    padding-bottom: 40px;
    border-bottom: 3px solid var(--color-border);
  }
  .project-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
  .project-icon-wrap {
    width: 96px;
    height: 96px;
    flex-shrink: 0;
  }
  .project-icon {
    width: 96px;
    height: 96px;
    border-radius: 20%;
    border: 3px solid var(--color-border);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-ink);
    object-fit: cover;
  }
  .project-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
  }
  .project-tagline {
    color: var(--color-text-dim);
    font-size: 1.1rem;
    max-width: 52ch;
  }
  .project-download-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }
  .download-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    padding: 24px;
    background: var(--color-surface);
    border: 3px solid var(--color-border);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-ink);
  }
  .download-cell-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
  .download-cell-platform {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }
  .button-primary {
    display: inline-block;
    padding: 13px 26px;
    background: var(--color-ink);
    color: var(--color-bg);
    border: 3px solid var(--color-ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: 4px 4px 0 var(--color-accent);
    transition:
      background-color 0.15s ease,
      color 0.15s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .button-primary:hover {
    background: var(--color-accent);
    color: var(--color-ink);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-ink);
  }
  .button-secondary {
    display: inline-block;
    margin-top: 20px;
    padding: 13px 26px;
    background: var(--color-bg);
    color: var(--color-text);
    border: 3px solid var(--color-border);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: 4px 4px 0 var(--color-ink);
    transition:
      background-color 0.15s ease,
      color 0.15s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .button-secondary:hover {
    background: var(--color-accent);
    color: var(--color-ink);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-ink);
  }
  .open-source-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }
  .open-source-item {
    display: block;
    background: var(--color-surface);
    border: 3px solid var(--color-border);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-ink);
    padding: 22px;
    text-decoration: none;
    color: var(--color-text);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .open-source-item:hover {
    transform: translate(-3px, -3px);
    box-shadow: calc(var(--shadow-offset) + 3px)
      calc(var(--shadow-offset) + 3px) 0 var(--color-ink);
  }
  .open-source-item h3 {
    font-size: 1.05rem;
    margin-bottom: 10px;
    color: var(--color-accent);
  }
  .open-source-item p {
    font-size: 0.92rem;
    color: var(--color-text-dim);
  }
  .project-section {
    padding-block: 40px;
    border-bottom: 3px solid var(--color-border);
  }
  .project-section:last-child {
    border-bottom: none;
  }
  .project-section h2 {
    font-size: 1.4rem;
    margin-bottom: 18px;
  }
  .project-section p {
    color: var(--color-text-dim);
    font-size: 1rem;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .feature-item {
    background: var(--color-surface);
    border: 3px solid var(--color-border);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-ink);
    padding: 22px;
  }
  .feature-item h3 {
    font-size: 1.05rem;
    margin-bottom: 10px;
  }
  .feature-item p {
    font-size: 0.92rem;
  }
  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
