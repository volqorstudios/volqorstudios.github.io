---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { projects } from "../../../data/projects.js";
export function getStaticPaths() {
  return projects.map((project) => ({
    params: { project: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const policy = project.privacyPolicy;
const description = `Politica de privacidad de ${project.name}, desarrollada por VOLQOR Studios.`;
---





<BaseLayout
  title={`Politica de privacidad de ${project.name}`}
  description={description}
  path={`/proyectos/${project.slug}/politica-de-privacidad/`}
>
  <article class="wrap privacy-policy">
    <a href={`/proyectos/${project.slug}/`} class="back-link">
      &larr; Volver a {project.name}
    </a>

    {
      policy ? (
        <>
          <header class="policy-header">
            <h1>{policy.appName || project.name}</h1>
            <p class="policy-subtitle">
              Politica de Privacidad por {policy.developer}
            </p>
            <p class="policy-date">Ultima actualizacion: {policy.lastUpdated}</p>
          </header>

          {policy.sections.map((section) => (
            <section class="policy-section">
              <h2>{section.title}</h2>
              <ul class="policy-list">
                {section.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          ))}

          {policy.commitment && (
            <section class="policy-commitment">
              <h2>{policy.commitment.title}</h2>
              <p>{policy.commitment.description}</p>
              <ul class="policy-highlights">
                {policy.commitment.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </section>
          )}

          {policy.important && (
            <section class="policy-important">
              <h2>Importante</h2>
              <p>{policy.important}</p>
            </section>
          )}
        </>
      ) : (
        <section class="policy-section">
          <h1>Politica de privacidad no disponible</h1>
          <p>
            Todavia no se ha publicado una politica de privacidad para este proyecto.
          </p>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .privacy-policy {
    padding-block: 56px 96px;
    max-width: 780px;
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-dim);
    text-decoration: none;
    margin-bottom: 40px;
  }
  .back-link:hover {
    color: var(--color-accent);
  }
  .policy-header {
    padding-bottom: 32px;
    border-bottom: 3px solid var(--color-border);
    margin-bottom: 40px;
  }
  .policy-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
  }
  .policy-subtitle {
    margin-top: 12px;
    color: var(--color-text-dim);
    font-size: 1rem;
  }
  .policy-date {
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }
  .policy-section {
    padding-block: 32px;
    border-bottom: 3px solid var(--color-border);
  }
  .policy-section:last-of-type {
    border-bottom: none;
  }
  .policy-section h2 {
    font-size: 1.3rem;
    margin-bottom: 18px;
  }
  .policy-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    padding-left: 20px;
    color: var(--color-text-dim);
    font-size: 0.98rem;
  }
  .policy-list li {
    padding-left: 4px;
  }
  .policy-commitment {
    padding-block: 32px;
    border-bottom: 3px solid var(--color-border);
    background: var(--color-surface);
    border-left: 3px solid var(--color-border);
    border-right: 3px solid var(--color-border);
    padding-inline: 28px;
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-ink);
  }
  .policy-commitment h2 {
    font-size: 1.3rem;
    margin-bottom: 16px;
  }
  .policy-commitment p {
    color: var(--color-text-dim);
    font-size: 0.98rem;
  }
  .policy-highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }
  .policy-highlights li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent);
    border: 2px solid var(--color-border);
    padding: 10px 14px;
  }
  .policy-important {
    padding-block: 32px;
  }
  .policy-important h2 {
    font-size: 1.3rem;
    margin-bottom: 18px;
  }
  .policy-important p {
    color: var(--color-text-dim);
    font-size: 0.98rem;
  }
</style>